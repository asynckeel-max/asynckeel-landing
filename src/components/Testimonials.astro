---
const testimonials = [
  {
    quote: '“AsyncKeel cut our backend setup from weeks to days.”',
    name: 'Alex M.',
    title: 'Indie Founder',
  },
  {
    quote: '“The auth + database layer alone saved us weeks of engineering time.”',
    name: 'Sarah K.',
    title: 'Backend Engineer',
  },
  {
    quote: '“Finally a FastAPI boilerplate that feels production-ready from day one.”',
    name: 'James T.',
    title: 'Solo Developer',
  },
];
---

<section class="border-t border-white/10 py-16 sm:py-20">
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Built by developers, for developers</h2>
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {
        testimonials.map((item) => (
          <article class="rounded-xl border border-white/10 bg-white/[0.02] p-5">
            <p class="text-zinc-200">{item.quote}</p>
            <p class="mt-4 font-semibold text-white">{item.name}</p>
            <p class="text-sm text-zinc-400">{item.title}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
