---
const faqs = [
  {
    question: 'Is there a free tier?',
    answer:
      'No. During beta we are offering only the Indie tier.',
  },
  {
    question: 'How does early-bird pricing work?',
    answer:
      'The first 100 waitlist signups receive a $49 Indie early-bird offer. After beta, Indie returns to the regular $79 price.',
  },
  {
    question: 'When will I be charged?',
    answer:
      'You are not charged on waitlist signup. You will receive an email with a purchase link when beta licenses open.',
  },
  {
    question: 'What does "one-time payment" mean?',
    answer:
      'Once purchased, you pay once and own the Indie license forever. No subscriptions or seat-based fees.',
  },
  {
    question: 'What is included in the beta build?',
    answer:
      'Beta includes auth, database layer, migrations, rate limiting, API versioning, and pagination.',
  },
  {
    question: 'What is planned next?',
    answer:
      'Month 3 roadmap includes RBAC, 2FA, OAuth2, and multi-tenant support.',
  },
];
---

<section id="faq" class="border-t border-white/10 py-16 sm:py-20">
  <div class="mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Frequently asked questions</h2>
    <div class="mt-8 space-y-3">
      {
        faqs.map((faq) => (
          <details class="group rounded-lg border border-white/10 bg-white/[0.02] p-4">
            <summary class="cursor-pointer list-none pr-6 font-medium text-white">
              {faq.question}
              <span class="float-right text-green-400 transition group-open:rotate-45">+</span>
            </summary>
            <p class="mt-3 text-sm leading-6 text-zinc-300">{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
