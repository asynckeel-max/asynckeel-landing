---
const faqs = [
  {
    question: 'Is AsyncKeel really free to use?',
    answer:
      'Yes. The Starter tier is 100% free and open source. You get the core scaffold with no limits or time restrictions.',
  },
  {
    question: 'What does "one-time payment" mean?',
    answer:
      'You pay once and own the license forever. No recurring fees, no subscriptions, no surprise charges.',
  },
  {
    question: 'What\'s included in "1 year of updates"?',
    answer:
      'All new features, bug fixes, and modules released within 12 months of your purchase date.',
  },
  {
    question: 'Do I need to know FastAPI?',
    answer:
      'Basic Python knowledge is enough. AsyncKeel is designed to be readable and well-documented.',
  },
  {
    question: 'Can I use AsyncKeel for client projects?',
    answer:
      'Yes. The Indie license covers one project. Studio covers unlimited projects and team members.',
  },
  {
    question: 'What payment methods do you accept?',
    answer:
      'Credit card, debit card, and PayPal via Gumroad/LemonSqueezy.',
  },
];
---

<section id="faq" class="border-t border-white/10 py-16 sm:py-20">
  <div class="mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Frequently asked questions</h2>
    <div class="mt-8 space-y-3">
      {
        faqs.map((faq) => (
          <details class="group rounded-lg border border-white/10 bg-white/[0.02] p-4">
            <summary class="cursor-pointer list-none pr-6 font-medium text-white">
              {faq.question}
              <span class="float-right text-green-400 transition group-open:rotate-45">+</span>
            </summary>
            <p class="mt-3 text-sm leading-6 text-zinc-300">{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
