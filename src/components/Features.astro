---
const features = [
  {
    icon: '🔐',
    title: 'JWT Authentication',
    description: 'Access + refresh token flows, production-hardened. No auth headaches.',
  },
  {
    icon: '👤',
    title: 'User Management',
    description: 'Registration, login, email verification, password reset — out of the box.',
  },
  {
    icon: '🗄️',
    title: 'Database Layer',
    description: 'SQLAlchemy ORM + PostgreSQL + Alembic migrations. Schema versioning from day one.',
  },
  {
    icon: '🚦',
    title: 'Rate Limiting',
    description: 'Protect your API from abuse with configurable rate limits per endpoint.',
  },
  {
    icon: '🔀',
    title: 'API Versioning',
    description: 'Ship v1, iterate to v2. Stable integrations, clean upgrade paths.',
  },
  {
    icon: '📄',
    title: 'Pagination',
    description: 'Standardized cursor and offset pagination for all list endpoints.',
  },
  {
    icon: '🛡️',
    title: 'CORS & Security',
    description: 'Sensible defaults for CORS, error handling, and input validation.',
  },
  {
    icon: '📊',
    title: 'Logging & Monitoring',
    description: 'Structured logs and monitoring hooks ready for production.',
  },
];
---

<section id="features" class="border-t border-white/10 bg-black/20 py-16 sm:py-20">
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
      Everything your backend needs. Nothing it doesn't.
    </h2>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        features.map((feature) => (
          <article class="rounded-xl border border-white/10 bg-white/[0.02] p-5">
            <p class="text-2xl">{feature.icon}</p>
            <h3 class="mt-4 text-lg font-semibold text-white">{feature.title}</h3>
            <p class="mt-2 text-sm leading-6 text-zinc-300">{feature.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
