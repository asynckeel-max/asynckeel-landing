---
const waitlistApiUrl = import.meta.env.PUBLIC_WAITLIST_API_URL || '/api/waitlist';
---

<section id="early-access" class="border-t border-white/10 py-16 sm:py-20">
  <div class="mx-auto w-full max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Get early-bird access</h2>
    <p class="mt-3 text-zinc-300">
      Lock in $49 early-bird pricing (first 100 signups) and join the beta waitlist.
    </p>

    <form
      id="waitlist-form"
      class="mx-auto mt-8 flex w-full max-w-xl flex-col gap-3 sm:flex-row"
      action={waitlistApiUrl}
      method="post"
      data-api-url={waitlistApiUrl}
    >
      <label for="email" class="sr-only">Email address</label>
      <input
        id="email"
        name="email"
        type="email"
        required
        placeholder="you@company.com"
        class="w-full rounded-lg border border-white/15 bg-black/50 px-4 py-3 text-white placeholder:text-zinc-500 focus:border-green-500 focus:outline-none"
      />
      <button
        type="submit"
        class="rounded-lg bg-gradient-to-r from-green-500 to-emerald-400 px-6 py-3 font-semibold text-black transition hover:brightness-110"
      >
        Get Early-Bird Access
      </button>
    </form>
    <p id="waitlist-feedback" class="mt-4 hidden text-sm" role="status" aria-live="polite"></p>
    <p class="mt-3 text-xs text-zinc-500">No spam. Unsubscribe anytime.</p>
  </div>
</section>

<script>
  const form = document.querySelector('#waitlist-form');
  const feedback = document.querySelector('#waitlist-feedback');

  if (form instanceof HTMLFormElement && feedback instanceof HTMLParagraphElement) {
    const emailInput = form.querySelector('#email');
    const submitButton = form.querySelector('button[type="submit"]');
    const defaultButtonText = submitButton?.textContent ?? 'Get Early-Bird Access';

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const email = emailInput instanceof HTMLInputElement ? emailInput.value.trim() : '';
      if (!email) {
        feedback.className = 'mt-4 text-sm text-red-300';
        feedback.textContent = 'Please enter a valid email address.';
        feedback.classList.remove('hidden');
        return;
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = 'Submitting...';
      }

      try {
        const response = await fetch(form.dataset.apiUrl || form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        const payload = await response.json().catch(() => ({}));

        if (!response.ok || !payload.ok) {
          throw new Error(payload?.error || 'Request failed');
        }

        const position = Number(payload.position);
        const earlyBird = Boolean(payload.earlyBird);

        let message = "You're on the list.";
        if (Number.isFinite(position) && position > 0) {
          message += ` You're #${position}.`;
        }
        message += earlyBird
          ? ' Early-bird is locked in (earlybird-49).'
          : ' Early-bird pricing is full; you are on the beta waitlist.';

        feedback.className = 'mt-4 text-sm text-green-300';
        feedback.textContent = message;
        feedback.classList.remove('hidden');
        form.reset();
      } catch {
        feedback.className = 'mt-4 text-sm text-red-300';
        feedback.textContent = 'Something went wrong. Please try again in a moment.';
        feedback.classList.remove('hidden');
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = defaultButtonText;
        }
      }
    });
  }
</script>
