<section id="early-access" class="border-t border-white/10 py-16 sm:py-20">
  <div class="mx-auto w-full max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Get early-bird access</h2>
    <p class="mt-3 text-zinc-300">
      Lock in $49 early-bird pricing (first 100 signups) and join the beta waitlist.
    </p>

    <!-- TODO: Replace action="#" with your Mailchimp/ConvertKit endpoint or embed handler -->
    <form class="mx-auto mt-8 flex w-full max-w-xl flex-col gap-3 sm:flex-row" action="#" method="post">
      <label for="email" class="sr-only">Email address</label>
      <input
        id="email"
        name="email"
        type="email"
        required
        placeholder="you@company.com"
        class="w-full rounded-lg border border-white/15 bg-black/50 px-4 py-3 text-white placeholder:text-zinc-500 focus:border-green-500 focus:outline-none"
      />
      <button
        type="submit"
        class="rounded-lg bg-gradient-to-r from-green-500 to-emerald-400 px-6 py-3 font-semibold text-black transition hover:brightness-110"
      >
        Get Early-Bird Access
      </button>
    </form>
    <p class="mt-3 text-xs text-zinc-500">No spam. Unsubscribe anytime.</p>
  </div>
</section>
